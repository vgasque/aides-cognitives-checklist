# En-têtes de sécurité — pris en charge par Netlify et Cloudflare Pages (fichier « _headers »).
# La CSP reste aussi présente en balise <meta> dans index.html pour l'ouverture hors hébergeur ;
# la servir en en-tête HTTP est plus robuste (couvre aussi les réponses non-HTML).
/*
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://xhvgiwcxaqcnacuiovhh.supabase.co; img-src 'self' data: blob:; media-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# Le service worker ne doit jamais être servi depuis un cache figé (sinon MAJ bloquées).
/sw.js
  Cache-Control: no-cache
