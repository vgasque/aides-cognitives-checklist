# En-têtes de sécurité — pris en charge par Netlify et Cloudflare Pages (fichier « _headers »).
# La CSP reste aussi présente en balise <meta> dans index.html pour l'ouverture hors hébergeur ;
# la servir en en-tête HTTP est plus robuste (couvre aussi les réponses non-HTML).
/*
  Content-Security-Policy: default-src 'self'; connect-src 'self' https://xhvgiwcxaqcnacuiovhh.supabase.co; img-src 'self' data: blob:; media-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'sha256-Eo1MPWra+DJX+w64+XvOEJ19j3c4oZ/SVU5KYQcjhqY=' 'sha256-tRheoqKCFWYYnlR09Ci6gzfWa374YbW54v8uOqmiFts='; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'; frame-ancestors 'none'
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), camera=(), microphone=()

# Le service worker ne doit jamais être servi depuis un cache figé (sinon MAJ bloquées).
/sw.js
  Cache-Control: no-cache

# La page elle-même non plus : la stratégie « réseau d'abord » du service worker suppose que son
# fetch atteint le serveur — servie depuis le cache HTTP, une vieille copie passerait pour fraîche.
/
  Cache-Control: no-cache
/index.html
  Cache-Control: no-cache
